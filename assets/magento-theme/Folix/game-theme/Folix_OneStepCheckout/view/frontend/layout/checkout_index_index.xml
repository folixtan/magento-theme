<?xml version="1.0"?>
<!--
/**
 * Folix One Step Checkout - Layout Configuration
 *
 * 实现一步结账：
 * 1. 使用自定义 onepage 模板（两列布局）
 * 2. 使用自定义 sidebar 模板
 * 3. 在 summary 区域添加 Place Order 按钮
 * 4. 禁用不需要的组件
 *
 * @category    Folix
 * @package     Folix_OneStepCheckout
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>

        <!-- 重写 checkout 主组件的模板 -->
        <referenceBlock name="checkout.root">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="checkout" xsi:type="array">
                            <item name="config" xsi:type="array">
                                <!-- 使用自定义 onepage 模板 -->
                                <item name="template" xsi:type="string">Folix_OneStepCheckout/onepage</item>
                            </item>
                            <item name="children" xsi:type="array">

                                <!-- 禁用进度条 -->
                                <item name="progressBar" xsi:type="array">
                                    <item name="config" xsi:type="array">
                                        <item name="componentDisabled" xsi:type="boolean">true</item>
                                    </item>
                                </item>

                                <!-- 禁用运费估算 -->
                                <item name="estimation" xsi:type="array">
                                    <item name="config" xsi:type="array">
                                        <item name="componentDisabled" xsi:type="boolean">true</item>
                                    </item>
                                </item>

                                <!-- 配置 steps -->
                                <item name="steps" xsi:type="array">
                                    <item name="children" xsi:type="array">

                                        <!-- 禁用 shipping-step -->
                                        <item name="shipping-step" xsi:type="array">
                                            <item name="config" xsi:type="array">
                                                <item name="componentDisabled" xsi:type="boolean">true</item>
                                            </item>
                                        </item>

                                        <!-- 配置 billing-step -->
                                        <item name="billing-step" xsi:type="array">
                                            <item name="children" xsi:type="array">
                                                <item name="payment" xsi:type="array">
                                                    <item name="children" xsi:type="array">
                                                        <!-- 确保支付方式渲染器可用 -->
                                                        <item name="renders" xsi:type="array">
                                                            <item name="config" xsi:type="array">
                                                                <item name="component" xsi:type="string">Magento_Checkout/js/view/payment/list</item>
                                                            </item>
                                                        </item>
                                                    </item>
                                                </item>
                                            </item>
                                        </item>

                                    </item>
                                </item>

                                <!-- 配置 sidebar -->
                                <item name="sidebar" xsi:type="array">
                                    <item name="config" xsi:type="array">
                                        <item name="template" xsi:type="string">Folix_OneStepCheckout/sidebar</item>
                                    </item>
                                    <item name="children" xsi:type="array">
                                        <!-- 在 summary 区域添加 Place Order 按钮 -->
                                        <item name="place-order-button" xsi:type="array">
                                            <item name="component" xsi:type="string">Folix_OneStepCheckout/js/view/place-order-button</item>
                                            <item name="sortOrder" xsi:type="string">100</item>
                                            <item name="config" xsi:type="array">
                                                <item name="template" xsi:type="string">Folix_OneStepCheckout/place-order-button</item>
                                                <item name="cartUrl" xsi:type="string" xsi:nil="true"/>
                                            </item>
                                        </item>
                                    </item>
                                </item>

                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>

    </body>
</page>
