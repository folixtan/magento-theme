<?php
/**
 * Folix Game Theme - Home Products List
 * 
 * 首页热销产品列表
 */
?>
<?php
$_productCollection = $block->getLoadedProductCollection();
$_helper = $this->helper(Magento\Catalog\Helper\Output::class);
$title = $block->getTitle() ?: __('Hot Products');
$subtitle = $block->getSubtitle();
?>

<?php if ($_productCollection && $_productCollection->count()): ?>
<div class="home-products-section">
    <?php if ($title): ?>
    <div class="section-title-wrapper">
        <h2 class="section-title"><?= $block->escapeHtml($title) ?></h2>
        <?php if ($subtitle): ?>
        <p class="section-subtitle"><?= $block->escapeHtml($subtitle) ?></p>
        <?php endif; ?>
    </div>
    <?php endif; ?>
    
    <div class="products-grid home-products-grid">
        <ol class="product-items">
            <?php foreach ($_productCollection as $_product): ?>
            <li class="product-item">
                <div class="product-item-info">
                    <!-- Product Image -->
                    <a href="<?= $block->escapeUrl($_product->getProductUrl()) ?>" class="product-item-photo">
                        <?= $block->getImage($_product, 'category_page_grid')->toHtml() ?>
                    </a>
                    
                    <!-- Product Details -->
                    <div class="product-item-details">
                        <!-- Product Name -->
                        <strong class="product-item-name">
                            <a title="<?= $block->escapeHtmlAttr($_product->getName()) ?>"
                               href="<?= $block->escapeUrl($_product->getProductUrl()) ?>"
                               class="product-item-link">
                                <?= $block->escapeHtml($_product->getName()) ?>
                            </a>
                        </strong>
                        
                        <!-- Price -->
                        <?= $block->getProductPrice($_product) ?>
                        
                        <!-- Add to Cart -->
                        <div class="product-item-actions">
                            <div class="actions-primary">
                                <?php if ($_product->isSaleable()): ?>
                                <button type="button"
                                        class="action tocart primary"
                                        data-post='<?= /* @noEscape */ $block->getAddToCartPostParams($_product) ?>'
                                        data-role="tocart">
                                    <span><?= $block->escapeHtml(__('Add to Cart')) ?></span>
                                </button>
                                <?php else: ?>
                                <span class="stock unavailable"><?= $block->escapeHtml(__('Out of Stock')) ?></span>
                                <?php endif; ?>
                            </div>
                        </div>
                    </div>
                </div>
            </li>
            <?php endforeach; ?>
        </ol>
    </div>
</div>

<script type="text/x-magento-init">
{
    "[data-role=tocart]": {
        "catalogAddToCart": {}
    }
}
</script>
<?php endif; ?>
