<?xml version="1.0"?>
<!--
/**
 * Folix Game Theme - Shopping Cart Layout Override
 *
 * 布局结构调整：
 * - 创建 .cart-main-content 容器包装 form-cart 和 cart-summary
 * - cart-discount 和 crosssell 保持在外层，占满全宽
 *
 * 最终结构：
 * .cart-container
 * ├── .cart-main-content (flex容器)
 * │   ├── form.form-cart (产品列表)
 * │   └── .cart-summary (摘要面板)
 * ├── .cart-discount (折扣码，全宽)
 * └── .block.crosssell (交叉销售，全宽)
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- 
            创建主内容容器，包装产品列表和摘要面板
            这样可以通过 CSS 实现两列布局
        -->
        <referenceContainer name="checkout.cart.container">
            <container name="cart.main.content" 
                       label="Cart Main Content Wrapper" 
                       htmlTag="div" 
                       htmlClass="cart-main-content" 
                       before="-" />
        </referenceContainer>
        
        <!-- 将产品列表移入主内容容器 -->
        <move element="checkout.cart.form" 
              destination="cart.main.content" 
              before="-" />
        
        <!-- 将摘要面板移入主内容容器，放在产品列表之后 -->
        <move element="cart.summary" 
              destination="cart.main.content" 
              after="checkout.cart.form" />
        
        <!-- 
            cart-discount 和 block.crosssell 已经在 checkout.cart.container 中
            它们会自动在 cart-main-content 下方显示，占满全宽
        -->
    </body>
</page>
