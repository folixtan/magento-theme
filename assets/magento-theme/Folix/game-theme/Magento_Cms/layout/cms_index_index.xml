<?xml version="1.0"?>
<!--
/**
 * Folix Game Theme - CMS Homepage Layout
 * 
 * 首页特定布局
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- 首页移除页面标题 -->
        <referenceBlock name="page.main.title" remove="true"/>
        
        <!-- 主内容区域 -->
        <referenceContainer name="content">
            <!-- 热销产品区块 -->
            <block class="Magento\Catalog\Block\Product\ListProduct" name="home.hot.products" template="Magento_Catalog::product/list/home-products.phtml">
                <arguments>
                    <argument name="title" xsi:type="string">🔥 热销产品</argument>
                    <argument name="subtitle" xsi:type="string">热门游戏充值，限时优惠</argument>
                </arguments>
            </block>
            
            <!-- 促销Banner -->
            <block class="Magento\Framework\View\Element\Template" name="home.promo.banner" after="home.hot.products" template="Magento_Theme::html/home/promo-banner.phtml"/>
        </referenceContainer>
    </body>
</page>
