<?xml version="1.0"?>
<!--
/**
 * Folix Game Theme - Customer Account Layout
 * 
 * 个人中心布局
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- 左侧导航 -->
        <referenceContainer name="sidebar.main">
            <block class="Magento\Customer\Block\Account\Navigation" name="customer_account_navigation" before="-" template="Magento_Customer::account/navigation.phtml">
                <arguments>
                    <argument name="css_class" xsi:type="string">account-nav</argument>
                </arguments>
                
                <!-- 账户仪表盘 -->
                <block class="Magento\Customer\Block\Account\SortLinkInterface" name="customer-account-navigation-account">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">My Dashboard</argument>
                        <argument name="path" xsi:type="string">customer/account</argument>
                        <argument name="sortOrder" xsi:type="number">10</argument>
                    </arguments>
                </block>
                
                <!-- 我的订单 -->
                <block class="Magento\Customer\Block\Account\SortLinkInterface" name="customer-account-navigation-orders">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">My Orders</argument>
                        <argument name="path" xsi:type="string">sales/order/history</argument>
                        <argument name="sortOrder" xsi:type="number">20</argument>
                    </arguments>
                </block>
                
                <!-- 我的愿望清单 -->
                <block class="Magento\Customer\Block\Account\SortLinkInterface" name="customer-account-navigation-wishlist">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">My Wishlist</argument>
                        <argument name="path" xsi:type="string">wishlist</argument>
                        <argument name="sortOrder" xsi:type="number">30</argument>
                    </arguments>
                </block>
                
                <!-- 地址簿 -->
                <block class="Magento\Customer\Block\Account\SortLinkInterface" name="customer-account-navigation-address-book">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Address Book</argument>
                        <argument name="path" xsi:type="string">customer/address</argument>
                        <argument name="sortOrder" xsi:type="number">40</argument>
                    </arguments>
                </block>
                
                <!-- 账户信息 -->
                <block class="Magento\Customer\Block\Account\SortLinkInterface" name="customer-account-navigation-account-edit">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Account Information</argument>
                        <argument name="path" xsi:type="string">customer/account/edit</argument>
                        <argument name="sortOrder" xsi:type="number">50</argument>
                    </arguments>
                </block>
                
                <!-- 退出登录 -->
                <block class="Magento\Customer\Block\Account\SortLinkInterface" name="customer-account-navigation-logout">
                    <arguments>
                        <argument name="label" xsi:type="string" translate="true">Sign Out</argument>
                        <argument name="path" xsi:type="string">customer/account/logout</argument>
                        <argument name="sortOrder" xsi:type="number">999</argument>
                    </arguments>
                </block>
            </block>
        </referenceContainer>
        
        <!-- 主内容区 -->
        <referenceContainer name="content">
            <block class="Magento\Customer\Block\Account\Dashboard\Info" name="customer_account_dashboard_info" template="Magento_Customer::account/dashboard/info.phtml" before="-"/>
            <block class="Magento\Customer\Block\Account\Dashboard\Address" name="customer_account_dashboard_address" template="Magento_Customer::account/dashboard/address.phtml" after="customer_account_dashboard_info"/>
            <block class="Magento\Sales\Block\Order\Recent" name="customer_account_dashboard_orders" template="Magento_Sales::order/recent.phtml" after="customer_account_dashboard_address"/>
        </referenceContainer>
    </body>
</page>
