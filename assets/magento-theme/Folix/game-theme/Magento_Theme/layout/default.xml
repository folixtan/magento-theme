<?xml version="1.0"?>
<!--
/**
 * Folix Game Theme - Default Layout
 * 
 * 继承机制说明：
 * 1. 新增容器：<container name="xxx" ...> 在 referenceContainer 内
 * 2. 移动元素：<move element="xxx" destination="yyy" />
 * 3. 删除元素：<referenceBlock name="xxx" remove="true" />
 * 4. 新增block：<block ...> 在容器内
 * 
 * 头部结构设计：
 * 
 * header.panel (Top Bar)
 * ├── folix.top.left (左侧：辅助链接)
 * ├── header-marquee (中间：跑马灯)
 * └── header-wrapper-right (右侧：APP下载、语言切换)
 * 
 * header-wrapper (Main Bar)
 * ├── logo [原生]
 * ├── navigation.sections [移动到此处]
 * ├── top.search [移动到此处]
 * ├── folix.login.button (登录按钮)
 * └── minicart [移动到此处]
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- =================================================================
             TOP BAR 结构重构
             在 header.panel 内新增三个容器：左 | 中 | 右
             ================================================================= -->
        
        <referenceContainer name="header.panel">
            <!-- 左侧容器：辅助链接 -->
            <container name="folix.top.left" label="Folix Top Left Links" htmlTag="div" htmlClass="header-wrapper-links-top" before="-" />
            
            <!-- 中间容器：跑马灯公告 -->
            <container name="header-marquee" label="Header Marquee" htmlTag="div" htmlClass="header-marquee" after="folix.top.left" />
            
            <!-- 右侧容器：APP下载、语言切换 -->
            <container name="header-wrapper-right" label="Folix Top Right" htmlTag="div" htmlClass="header-wrapper-right" after="header-marquee" />
        </referenceContainer>
        
        <!-- =================================================================
             移除不需要的原生元素
             ================================================================= -->
        
        <referenceBlock name="header.links" remove="true" />
        <referenceBlock name="skip_to_content" remove="true" />
        <referenceBlock name="catalog.compare.link" remove="true" />
        <referenceBlock name="currency" remove="true" />
        
        <!-- =================================================================
             移动原生元素到新位置
             ================================================================= -->
        
        <!-- 移动语言切换到右侧容器 -->
        <move element="store_language" destination="header-wrapper-right" />
        
        <!-- 移动导航到 header-wrapper -->
        <move element="navigation.sections" destination="header-wrapper" after="logo" />
        
        <!-- 移动搜索框到 header-wrapper -->
        <move element="top.search" destination="header-wrapper" after="navigation.sections" />
        
        <!-- 移动购物车到 header-wrapper -->
        <move element="minicart" destination="header-wrapper" after="top.search" />
        
        <!-- =================================================================
             为新增容器添加内容
             ================================================================= -->
        
        <!-- 左侧容器：辅助链接 -->
        <referenceContainer name="folix.top.left">
            <block class="Magento\Framework\View\Element\Template" name="folix.game.top.links" template="Magento_Theme::html/header/links-top-left.phtml" before="-" />
        </referenceContainer>
        
        <!-- 中间容器：跑马灯 -->
        <referenceContainer name="header-marquee">
            <block class="Magento\Framework\View\Element\Template" name="folix.marquee" template="Magento_Theme::html/header/marquee.phtml" before="-" />
        </referenceContainer>
        
        <!-- 右侧容器：APP下载链接 -->
        <referenceContainer name="header-wrapper-right">
            <block class="Magento\Framework\View\Element\Template" name="folix.app.link" template="Magento_Theme::html/header/app-link.phtml" before="store_language" />
        </referenceContainer>
        
        <!-- =================================================================
             MAIN BAR - 登录按钮
             ================================================================= -->
        
        <referenceContainer name="header.content">
            <block class="Magento\Framework\View\Element\Template" name="folix.login.button" template="Magento_Theme::html/header/login-button.phtml" after="logo" />
        </referenceContainer>
        
        <!-- =================================================================
             FOOTER 结构重构
             ================================================================= -->
        
        <referenceContainer name="footer">
            <!-- 移除默认 store_switcher -->
            <referenceBlock name="store_switcher" remove="true" />
        </referenceContainer>
        
        <!-- 添加自定义链接到 footer_links -->
        <referenceBlock name="footer_links">
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="footer-link-about">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">About Us</argument>
                    <argument name="path" xsi:type="string">about-us</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="footer-link-terms">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">Terms of Service</argument>
                    <argument name="path" xsi:type="string">terms</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="footer-link-privacy">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">Privacy Policy</argument>
                    <argument name="path" xsi:type="string">privacy-policy</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="footer-link-contact">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">Contact Us</argument>
                    <argument name="path" xsi:type="string">contact</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="footer-link-faq">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">FAQ</argument>
                    <argument name="path" xsi:type="string">faq</argument>
                </arguments>
            </block>
        </referenceBlock>
        
        <!-- 移动 copyright 到 before.body.end -->
        <move element="copyright" destination="before.body.end" />
        
        <!-- 添加自定义版权区块 -->
        <referenceContainer name="footer">
            <block class="Magento\Framework\View\Element\Template" name="folix.footer.copyright" template="Magento_Theme::html/footer/copyright.phtml" after="-" />
        </referenceContainer>
        
        <!-- =================================================================
             PAGE TOP - Hero Slider
             ================================================================= -->
        
        <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template" name="hero.slider" before="navigation.sections" template="Magento_Theme::html/slider/hero.phtml" />
        </referenceContainer>
        
        <!-- =================================================================
             LOGIN MODAL
             ================================================================= -->
        
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template" name="login.modal" template="Magento_Theme::html/modal/login.phtml" />
        </referenceContainer>
        
        <!-- =================================================================
             BODY ATTRIBUTES
             ================================================================= -->
        
        <attribute name="body" value="folix-theme" />
        
    </body>
</page>
