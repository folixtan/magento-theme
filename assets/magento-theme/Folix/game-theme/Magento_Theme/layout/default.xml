<?xml version="1.0"?>
<!--
/**
 * Folix Game Theme - Default Layout Extensions
 * 
 * Extends Luma theme layout using reference blocks
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!--
            Header Extensions
            Using referenceContainer to add custom blocks
        -->
        
        <!-- Add hero slider to homepage -->
        <referenceContainer name="main.content">
            <block class="Magento\Cms\Block\Block" name="hero.slider" before="-">
                <arguments>
                    <argument name="block_id" xsi:type="string">hero_slider</argument>
                </arguments>
            </block>
        </referenceContainer>
        
        <!-- Add promo banner -->
        <referenceContainer name="content">
            <block class="Magento\Cms\Block\Block" name="promo.banner" after="category.products.list">
                <arguments>
                    <argument name="block_id" xsi:type="string">promo_banner</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
