<?xml version="1.0"?>
<!--
/**
 * Folix Game Theme - Default Layout
 * 
 * 头部结构（严格按原型）：
 * 
 * Top Bar (header.panel) - 深蓝渐变背景，高度40px
 * ├── 左侧：新闻、奖励、支持链接
 * └── 右侧：APP下载、语言切换
 * 
 * Main Bar (header.content) - 白色背景，高度70px，底部橙色边框3px
 * ├── Logo
 * ├── 导航菜单
 * ├── 搜索框
 * └── 登录按钮
 * 
 * 注意：跑马灯不在header内，可能在page.top区域
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- =================================================================
             TOP BAR - 顶部栏
             深蓝渐变背景，高度40px
             左侧：链接 | 右侧：APP + 语言切换
             ================================================================= -->
        
        <referenceContainer name="header.panel">
            <!-- 左侧链接容器 -->
            <container name="folix.top.left" label="Folix Top Left Links" htmlTag="div" htmlClass="header-links-left" before="-" />
            
            <!-- 中间容器（跑马灯或留空） -->
            <container name="folix.top.center" label="Folix Top Center" htmlTag="div" htmlClass="header-links-center" after="folix.top.left" />
            
            <!-- 右侧容器 -->
            <container name="folix.top.right" label="Folix Top Right" htmlTag="div" htmlClass="header-links-right" after="folix.top.center" />
        </referenceContainer>
        
        <!-- 移除不需要的原生元素 -->
        <!-- 注意：不要移除 header.links，它在移动端会显示在 Account 标签页中 -->
        <referenceBlock name="skip_to_content" remove="true" />
        <referenceBlock name="catalog.compare.link" remove="true" />
        <referenceBlock name="currency" remove="true" />
        
        <!-- 移动语言切换到右侧容器 -->
        <move element="store_language" destination="folix.top.right" />
        
        <!-- 左侧链接内容 -->
        <referenceContainer name="folix.top.left">
            <block class="Magento\Framework\View\Element\Template" name="folix.top.links" template="Magento_Theme::html/header/links-top-left.phtml" before="-" />
        </referenceContainer>
        
        <!-- 右侧APP链接 -->
        <referenceContainer name="folix.top.right">
            <block class="Magento\Framework\View\Element\Template" name="folix.app.link" template="Magento_Theme::html/header/app-link.phtml" before="store_language" />
        </referenceContainer>
        
        <!-- =================================================================
             MAIN BAR - 主导航栏
             白色背景，底部橙色边框3px
             Logo | 导航 | 搜索 | 登录按钮
             
             移动端重构：
             1. 删除navigation.sections（标签页导航）
             2. 重新添加topmenu到header-wrapper
             ================================================================= -->
        
        <!-- 删除原生标签页导航 -->
        <referenceBlock name="navigation.sections" remove="true" />
        
        <!-- 移动搜索框到正确位置 -->
        <move element="top.search" destination="header-wrapper" before="minicart" />
        
        <!-- 添加导航菜单和登录按钮 -->
        <referenceContainer name="header-wrapper">
            <!-- 导航菜单（移动端和桌面端共用） -->
            <block class="Magento\Theme\Block\Html\Topmenu" name="catalog.topnav" template="Magento_Theme::html/topmenu.phtml" before="-" />
            
            <!-- 登录按钮 -->
            <block class="Magento\Framework\View\Element\Template" name="folix.login.button" template="Magento_Theme::html/header/login-button.phtml" after="minicart" />
        </referenceContainer>
        
        <!-- =================================================================
             PAGE TOP - Hero Slider
             首页专用，在main.content之前
             ================================================================= -->
        
        <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template" name="hero.slider" before="-" template="Magento_Theme::html/slider/hero.phtml" />
        </referenceContainer>
        
        <!-- =================================================================
             FOOTER
             ================================================================= -->
        
        <referenceContainer name="footer">
            <referenceBlock name="store_switcher" remove="true" />
        </referenceContainer>
        
        <referenceBlock name="footer_links">
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="footer-link-about">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">About Us</argument>
                    <argument name="path" xsi:type="string">about-us</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="footer-link-terms">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">Terms of Service</argument>
                    <argument name="path" xsi:type="string">terms</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="footer-link-privacy">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">Privacy Policy</argument>
                    <argument name="path" xsi:type="string">privacy-policy</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="footer-link-contact">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">Contact Us</argument>
                    <argument name="path" xsi:type="string">contact</argument>
                </arguments>
            </block>
            <block class="Magento\Framework\View\Element\Html\Link\Current" name="footer-link-faq">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">FAQ</argument>
                    <argument name="path" xsi:type="string">faq</argument>
                </arguments>
            </block>
        </referenceBlock>
        
        <move element="copyright" destination="before.body.end" />
        
        <referenceContainer name="footer">
            <block class="Magento\Framework\View\Element\Template" name="folix.footer.copyright" template="Magento_Theme::html/footer/copyright.phtml" after="-" />
        </referenceContainer>
        
        <!-- =================================================================
             LOGIN MODAL
             ================================================================= -->
        
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template" name="login.modal" template="Magento_Theme::html/modal/login.phtml" />
        </referenceContainer>
        
        <!-- Body Class -->
        <attribute name="body" value="folix-theme" />
        
    </body>
</page>
