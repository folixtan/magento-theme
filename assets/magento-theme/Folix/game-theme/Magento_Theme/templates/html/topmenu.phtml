<?php
/**
 * Folix Game Theme - Top Menu
 *
 * 基于 Magento 原生模板，添加 css_class 参数支持
 *
 * @var $block \Magento\Theme\Block\Html\Topmenu
 */

$columnsLimit = $block->getColumnsLimit() ?: 0;
$_menuHtml = $block->getHtml('level-top', 'submenu', $columnsLimit);
// 通过 hasData/getData 获取 layout 传入的 css_class 参数
$cssClass = '';
if ($block->hasData('css_class')) {
    $cssClass = $block->getData('css_class');
}
?>

<nav class="navigation <?= $block->escapeHtmlAttr($cssClass) ?>" data-action="navigation">
    <ul data-mage-init='{"menu":{"responsive":true, "expanded":true, "position":{"my":"left top","at":"left bottom"}}}'>
        <?= /* @noEscape */ $_menuHtml ?>
        <?= $block->getChildHtml() ?>
    </ul>
</nav>
