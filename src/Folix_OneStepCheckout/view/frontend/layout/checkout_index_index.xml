<?xml version="1.0" encoding="UTF-8"?>
<!--
/**
 * Folix One Step Checkout - Checkout Layout Override
 * 
 * 虚拟商品的一步结账
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- 禁用 progressBar -->
        <referenceBlock name="checkout.root">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <!-- 禁用 checkout 下的 progressBar 和 estimation -->
                        <item name="checkout" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="progressBar" xsi:type="array">
                                    <item name="config" xsi:type="array">
                                        <item name="componentDisabled" xsi:type="boolean">true</item>
                                    </item>
                                </item>
                                <item name="estimation" xsi:type="array">
                                    <item name="config" xsi:type="array">
                                        <item name="componentDisabled" xsi:type="boolean">true</item>
                                    </item>
                                </item>
                            </item>
                        </item>
                        
                        <!-- 禁用 shipping-step -->
                        <item name="steps" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="shipping-step" xsi:type="array">
                                    <item name="config" xsi:type="array">
                                        <item name="componentDisabled" xsi:type="boolean">true</item>
                                    </item>
                                </item>
                            </item>
                        </item>
                        
                        <!-- 修改 sidebar -->
                        <item name="sidebar" xsi:type="array">
                            <item name="config" xsi:type="array">
                                <item name="template" xsi:type="string">Folix_OneStepCheckout/sidebar</item>
                            </item>
                            <item name="children" xsi:type="array">
                                <!-- 必须保留 summary，否则摘要就不显示了 -->
                                <item name="summary" xsi:type="array">
                                    <item name="component" xsi:type="string">Magento_Checkout/js/view/summary</item>
                                    <item name="displayArea" xsi:type="string">summary</item>
                                    <item name="config" xsi:type="array">
                                        <item name="template" xsi:type="string">Magento_Checkout/summary</item>
                                    </item>
                                </item>
                                <!-- 添加 place-order -->
                                <item name="place-order" xsi:type="array">
                                    <item name="component" xsi:type="string">Folix_OneStepCheckout/js/view/place-order-button</item>
                                    <item name="displayArea" xsi:type="string">place-order</item>
                                    <item name="sortOrder" xsi:type="string">100</item>
                                    <item name="config" xsi:type="array">
                                        <item name="template" xsi:type="string">Folix_OneStepCheckout/place-order-button</item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
